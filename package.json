{
  "dependencies": {
    "astro": "6.0.8"
  },
  "name": "blog",
  "engines": {
    "node": ">=24.0.0"
  },
  "packageManager": "bun@1.3.10",
  "private": true,
  "scripts": {
    "build": "bun run redirects:generate && astro build",
    "check": "astro check",
    "content:generate": "bun scripts/convert-hatena-export.mjs backup/treeapps.hatenablog.com.export.txt --output src/content/blog && bun run redirects:generate",
    "deploy": "bun run build && WRANGLER_LOG_PATH=.wrangler-logs bunx wrangler deploy",
    "dev": "bun run redirects:generate && astro dev",
    "images:download": "bun scripts/download-hatena-images.mjs src/content/blog --output public/hatena-images",
    "preview": "astro preview",
    "redirects:generate": "bun scripts/generate-hatena-pagination-redirects.mjs"
  },
  "type": "module",
  "devDependencies": {
    "@astrojs/check": "^0.9.8",
    "typescript": "^5.9.3"
  }
}

{
  "name": "blog",
  "type": "module",
  "private": true,
  "scripts": {
    "update-deps": "bunx @astrojs/upgrade && bunx npm-check-updates -u && bun install",
    "build": "bun run redirects:generate && astro build",
    "check": "astro check",
    "content:generate": "bun scripts/convert-hatena-export.ts backup/treeapps.hatenablog.com.export.txt --output src/content/blog && bun run redirects:generate",
    "deploy": "bun run build && WRANGLER_LOG_PATH=.wrangler-logs bunx wrangler deploy",
    "dev": "bun run redirects:generate && astro dev",
    "images:download": "bun scripts/download-hatena-images.ts src/content/blog --output public/hatena-images",
    "preview": "astro preview",
    "redirects:generate": "bun scripts/generate-hatena-pagination-redirects.ts",
    "new-post": "bun scripts/create-article.ts",
    "x-post": "bun scripts/generate-x-post-text.ts",
    "x-card": "bun scripts/generate-x-card-images.ts"
  },
  "dependencies": {
    "astro": "6.1.3"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.8",
    "@tailwindcss/vite": "^4.2.2",
    "tailwindcss": "^4.2.2",
    "typescript": "^6.0.2"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "packageManager": "bun@1.3.11"
}

---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getPageHref, getPageSlice, getPaginationItems, getSortedPosts, getTagHref } from '../lib/blog';

const sortedPosts = await getSortedPosts();
const { posts, totalPages } = getPageSlice(sortedPosts, 1);
const primaryLinks = [
  {
    href: '/about/',
    label: 'このサイトについて',
    external: false,
  },
  {
    href: 'https://treeapps.hatenablog.com/',
    label: '旧はてなブログ',
    external: true,
  },
];
const secondaryLinks = [
  {
    href: 'https://www.tree-maps.com/',
    label: 'tree-maps',
    external: true,
    icon: '/icon/map-pin-01.png',
  },
  {
    href: 'https://www.string-utility.com/',
    label: 'String Utility',
    external: true,
    icon: '/icon/string-utility_512x512.png',
  },
  {
    href: 'https://github.com/treetips',
    label: 'GitHub',
    external: true,
    icon: '/icon/github-logos/GitHub_Invertocat_Black.svg',
  },
];
const paginationItems = getPaginationItems(1, totalPages);
const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: '文系プログラマによるTIPSブログ',
  url: new URL('/', Astro.site ?? Astro.url).toString(),
};
---

<BaseLayout
  title="文系プログラマによるTIPSブログ"
  description="はてなブログから移行した Astro + Markdown のブログです。"
  structuredData={structuredData}
>
  <header class="block p-8 max-md:p-4">
    <div class="w-full">
      <div class="flex w-full items-center justify-between gap-4 max-md:gap-2">
        <h1 class="m-0 flex-1 min-w-0 text-[clamp(2rem,3vw,3.4rem)] leading-[1.1] tracking-[-0.04em]">
          <a class="site-title-link" href="/" aria-label="トップページへ戻る">文系プログラマによるTIPSブログ</a>
        </h1>
        <div class="site-header-search ml-auto mr-0 w-full max-w-[24rem] flex-[0_1_24rem] max-md:ml-0 max-md:w-auto max-md:max-w-none max-md:flex-none"></div>
      </div>
    </div>
  </header>

  <main class="px-8 pb-8 max-md:px-4">
    <section class="about-link-frame liquid-glass liquid-glass--compact liquid-shadow" aria-label="このサイトについて">
      <h2 class="panel-title">個別ページ</h2>
      <div class="grid gap-3 md:grid-cols-2">
        <div class="min-w-0">
          <h3 class="panel-subtitle">サイト内リンク</h3>
          <ul class="about-link-list">
            {primaryLinks.map((link) => (
              <li>
                <a
                  class="about-link-title"
                  href={link.href}
                  target={link.external ? '_blank' : undefined}
                  rel={link.external ? 'nofollow noopener noreferrer' : undefined}
                >
                  {link.label}
                </a>
              </li>
            ))}
          </ul>
        </div>

        <div class="min-w-0 border-t border-site-border pt-2 md:border-t-0 md:border-l md:pt-0 md:pl-3">
          <h3 class="panel-subtitle">サイト外リンク</h3>
          <ul class="about-link-list">
            {secondaryLinks.map((link) => (
              <li>
                <a
                  class:list={[
                    'about-link-title',
                    link.icon && 'about-link-title--with-icon',
                  ]}
                  href={link.href}
                  target={link.external ? '_blank' : undefined}
                  rel={link.external ? 'nofollow noopener noreferrer' : undefined}
                >
                  {link.icon && (
                    <img
                      class="about-link-icon"
                      src={link.icon}
                      alt=""
                      width="20"
                      height="20"
                      aria-hidden="true"
                    />
                  )}
                  {link.label}
                </a>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </section>

    <section class="post-list-frame liquid-glass liquid-glass--subtle liquid-shadow">
      <h2 class="panel-title">記事一覧</h2>
      <ul class="post-list">
        {posts.map((post) => (
          <li class="post-card post-card--home">
            <h2 class="m-0 text-[clamp(1.55rem,2.2vw,1.72rem)] font-extrabold leading-[1.2] tracking-[-0.01em]">
              <a href={`/entry/${post.id}/`}>{post.data.title}</a>
            </h2>
            <div class="meta">
              <time datetime={post.data.publishedAt.toISOString()}>
                {post.data.publishedAt.toLocaleDateString('ja-JP')}
              </time>
            </div>
            {post.data.categories.length > 0 && (
              <ul class="categories">
                {post.data.categories.map((category: string) => (
                  <li>
                    <a href={getTagHref(category)}>{category}</a>
                  </li>
                ))}
              </ul>
            )}
          </li>
        ))}
      </ul>
    </section>

    {totalPages > 1 && (
      <nav class="pagination liquid-glass liquid-glass--compact liquid-shadow pagination--glass" aria-label="記事一覧のページ送り">
        <span class="pagination-prev is-disabled" aria-disabled="true">
          前へ
        </span>

        <div class="pagination-pages" aria-label="ページ番号">
          {paginationItems.map((item) =>
            item.type === 'ellipsis' ? (
              <span class="pagination-ellipsis" aria-hidden="true">
                ...
              </span>
            ) : item.current ? (
              <span class="pagination-current" aria-current="page">
                {item.page}
              </span>
            ) : (
              <a class="pagination-page" href={item.href}>
                {item.page}
              </a>
            ),
          )}
        </div>

        <a class="pagination-next" href={getPageHref(2)}>
          次へ
        </a>
      </nav>
    )}
  </main>
</BaseLayout>

---
import AboutLinksPanel from '../../components/AboutLinksPanel.astro';
import BlogListHeader from '../../components/BlogListHeader.astro';
import PaginationNav from '../../components/PaginationNav.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import {
getPageHref,
getPageSlice,
getPaginationItems,
getSortedPosts,
getTagHref,
getTotalPages,
} from '../../lib/blog';

export async function getStaticPaths() {
  const sortedPosts = await getSortedPosts();
  const totalPages = getTotalPages(sortedPosts.length);

  return Array.from({ length: Math.max(0, totalPages - 1) }, (_, index) => {
    const page = index + 2;
    return {
      params: { page: String(page) },
      props: { page },
    };
  });
}

const { page } = Astro.props;
const pageNumber = Number(page);
const sortedPosts = await getSortedPosts();
const pageData = getPageSlice(sortedPosts, pageNumber);
const posts = pageData.posts;
const totalPages = pageData.totalPages;
const hasPrevPage = pageNumber > 1;
const hasNextPage = pageNumber < totalPages;
const prevPageHref = getPageHref(pageNumber - 1);
const nextPageHref = getPageHref(pageNumber + 1);
const paginationItems = getPaginationItems(pageNumber, totalPages);
---

<BaseLayout
  title={`文系プログラマによるTIPSブログ - ${pageNumber}ページ目`}
  description="はてなブログから移行した Astro + Markdown のブログです。"
>
  <BlogListHeader />

  <main class="px-8 pb-8 max-md:px-4">
    <AboutLinksPanel />

    <section class="post-list-frame liquid-glass liquid-glass--subtle liquid-shadow">
      <h2 class="panel-title">記事一覧</h2>
      <PaginationNav
        className="pagination--inside-top"
        hasPrevPage={hasPrevPage}
        hasNextPage={hasNextPage}
        prevPageHref={prevPageHref}
        nextPageHref={nextPageHref}
        paginationItems={paginationItems}
      />
      <ul class="post-list">
        {posts.map((post) => (
          <li class="post-card post-card--home">
            <h2 class="m-0 text-[clamp(1.55rem,2.2vw,1.72rem)] font-extrabold leading-[1.2] tracking-[-0.01em]">
              <a href={`/entry/${post.id}/`}>{post.data.title}</a>
            </h2>
            <div class="meta">
              <time datetime={post.data.publishedAt.toISOString()}>
                {post.data.publishedAt.toLocaleDateString('ja-JP')}
              </time>
            </div>
            {post.data.categories.length > 0 && (
              <ul class="categories">
                {post.data.categories.map((category: string) => (
                  <li>
                    <a href={getTagHref(category)}>{category}</a>
                  </li>
                ))}
              </ul>
            )}
          </li>
        ))}
      </ul>
      <PaginationNav
        hasPrevPage={hasPrevPage}
        hasNextPage={hasNextPage}
        prevPageHref={prevPageHref}
        nextPageHref={nextPageHref}
        paginationItems={paginationItems}
      />
    </section>
  </main>
</BaseLayout>

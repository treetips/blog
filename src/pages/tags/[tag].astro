---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getSortedPosts } from '../../lib/blog';

function decodeTag(value: string) {
  try {
    return decodeURIComponent(value);
  } catch {
    return value;
  }
}

function tagHref(tag: string) {
  return `/tags/${encodeURIComponent(tag)}/`;
}

export async function getStaticPaths() {
  const posts = await getSortedPosts();
  const tags = [...new Set(posts.flatMap((post) => post.data.categories))].sort((a, b) =>
    a.localeCompare(b, 'ja'),
  );

  return tags.map((tag) => ({
    params: { tag },
    props: { tag },
  }));
}

const { tag } = Astro.props;
const decodedTag = decodeTag(tag);
const posts = (await getSortedPosts()).filter((post) => post.data.categories.includes(decodedTag));
---

<BaseLayout title={`タグ: ${decodedTag}`} description={`${decodedTag} に属する記事一覧です。`}>
  <header class="block p-8 max-md:p-4">
    <div class="w-full">
      <div class="flex w-full items-center justify-between gap-4 max-md:gap-2">
        <p class="m-0 whitespace-nowrap text-site-muted">
          <a href="/">Home</a>
        </p>
        <div class="site-header-search ml-auto mr-0 w-full max-w-[24rem] flex-[0_1_24rem] max-md:ml-0 max-md:w-auto max-md:max-w-none max-md:flex-none"></div>
      </div>
      <h1 class="m-0 flex-1 min-w-0 text-[clamp(2rem,3vw,3.4rem)] leading-[1.1] tracking-[-0.04em]">タグ: {decodedTag}</h1>
      <p class="mt-2.5 max-w-[60ch] text-site-muted">{posts.length}件の記事があります。</p>
    </div>
  </header>

  <main class="px-8 pb-8 max-md:px-4">
    <ul class="post-list">
      {posts.map((post) => (
        <li class="post-card">
          <h2 class="m-0 text-[clamp(1.55rem,2.2vw,1.72rem)] font-extrabold leading-[1.2] tracking-[-0.01em]">
            <a href={`/entry/${post.id}/`}>{post.data.title}</a>
          </h2>
          <div class="meta">
            <time datetime={post.data.publishedAt.toISOString()}>
              {post.data.publishedAt.toLocaleDateString('ja-JP')}
            </time>
          </div>
          {post.data.categories.length > 0 && (
            <ul class="categories">
              {post.data.categories.map((category: string) => (
                <li>
                  <a href={tagHref(category)}>{category}</a>
                </li>
              ))}
            </ul>
          )}
        </li>
      ))}
    </ul>
  </main>
</BaseLayout>

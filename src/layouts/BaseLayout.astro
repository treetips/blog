---
import '../styles/global.css';
import '../styles/liquid-glass.css';
import articleGlassStylesUrl from '../styles/article-glass.css?url';

const {
  title = '文系プログラマによるTIPSブログ',
  description = 'はてなブログから移行した技術メモと日記。',
  image,
  ogType = 'website',
  structuredData = [],
  panelClass = '',
} = Astro.props;

const baseUrl = Astro.site ?? new URL('https://bunkei-programmer.net');
const canonical = new URL(Astro.url.pathname, baseUrl).toString();
const siteTitle = '文系プログラマによるTIPSブログ';
const socialImage = image ? new URL(image, baseUrl).toString() : undefined;
const socialImageAlt = image ? title : undefined;
const jsonLdItems = Array.isArray(structuredData) ? structuredData : [structuredData];
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="alternate" type="application/rss+xml" title={siteTitle} href={new URL('/rss.xml', baseUrl).toString()} />
    <meta name="robots" content="index,follow" />
    <meta property="og:site_name" content={siteTitle} />
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonical} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    {socialImage && <meta property="og:image" content={socialImage} />}
    {socialImageAlt && <meta property="og:image:alt" content={socialImageAlt} />}
    <meta name="twitter:card" content={socialImage ? 'summary_large_image' : 'summary'} />
    <meta name="twitter:url" content={canonical} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    {socialImage && <meta name="twitter:image" content={socialImage} />}
    {socialImageAlt && <meta name="twitter:image:alt" content={socialImageAlt} />}
    {ogType === 'article' && <link rel="stylesheet" href={articleGlassStylesUrl} />}
    <link rel="stylesheet" href="https://unpkg.com/@algolia/sitesearch@latest/dist/search.min.css" />
    <script is:inline async src="https://www.googletagmanager.com/gtag/js?id=G-PKB6YJE88Z"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());

      gtag('config', 'G-PKB6YJE88Z');
    </script>
    {jsonLdItems.map((item) => (
      <script is:inline type="application/ld+json" set:html={JSON.stringify(item).replace(/</g, '\\u003c')} />
    ))}
  </head>
  <body>
    <div id="top"></div>
    {ogType === 'article' && (
      <svg width="0" height="0" aria-hidden="true" focusable="false" style="position: absolute;">
        <defs>
          <filter id="glass-distortion" x="0%" y="0%" width="100%" height="100%">
            <feTurbulence type="fractalNoise" baseFrequency="0.01 0.01" numOctaves="2" seed="92" result="noise" />
            <feGaussianBlur in="noise" stdDeviation="2" result="blurred" />
            <feDisplacementMap
              in="SourceGraphic"
              in2="blurred"
              scale="55"
              xChannelSelector="R"
              yChannelSelector="G"
            />
          </filter>
        </defs>
      </svg>
    )}
    <div class="shell">
      <div class={`panel ${panelClass}`.trim()}>
        <slot />
        <div id="search" class="site-search" role="search" aria-label="サイト内検索"></div>
        <script is:inline src="https://unpkg.com/@algolia/sitesearch@latest/dist/search.min.js"></script>
        <script is:inline>
          const searchContainer = document.getElementById('search');
          const searchHost = document.querySelector('.site-header-search');
          const siteHeader = document.querySelector('.site-header');

          if (searchContainer && searchHost) {
            searchHost.appendChild(searchContainer);
          } else if (searchContainer && siteHeader) {
            siteHeader.appendChild(searchContainer);
          }

          SiteSearch.init({
            container: '#search',
            applicationId: 'LDI14IJOZS',
            apiKey: '7a0ef963c4a89f7a3dbe6fb174d0602f',
            indexName: 'bunkei_programmer_net_ldi14ijozs_pages',
            attributes: {
              primaryText: 'title',
              secondaryText: 'description',
              tertiaryText: 'path',
              url: 'path',
              image: '',
            },
            darkMode: false,
          });
        </script>
      </div>
    </div>
    <div class="floating-actions" aria-label="ページ操作">
      <a class="floating-action liquid-shadow" href="/" aria-label="トップページへ移動" title="Homeに戻る">
        <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
          <path
            d="M4.5 10.6L12 4l7.5 6.6v8.4a1 1 0 0 1-1 1h-4.6v-6h-3.8v6H5.5a1 1 0 0 1-1-1z"
            fill="none"
            stroke="currentColor"
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="1.8"
          />
        </svg>
      </a>
      <a class="floating-action scroll-to-top liquid-shadow" href="#top" aria-label="トップへ戻る" title="トップにスクロール">
        ↑
      </a>
    </div>
  </body>
</html>

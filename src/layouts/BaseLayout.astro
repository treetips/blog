---
import '../styles/global.css';

const {
  title = '文系プログラマによるTIPSブログ',
  description = 'はてなブログから移行した技術メモと日記。',
  image,
  ogType = 'website',
  structuredData = [],
} = Astro.props;

const baseUrl = Astro.site ?? new URL('https://bunkei-programmer.net');
const canonical = new URL(Astro.url.pathname, baseUrl).toString();
const siteTitle = '文系プログラマによるTIPSブログ';
const socialImage = image ? new URL(image, baseUrl).toString() : undefined;
const jsonLdItems = Array.isArray(structuredData) ? structuredData : [structuredData];
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="alternate" type="application/rss+xml" title={siteTitle} href={new URL('/rss.xml', baseUrl).toString()} />
    <meta name="robots" content="index,follow" />
    <meta property="og:site_name" content={siteTitle} />
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonical} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    {socialImage && <meta property="og:image" content={socialImage} />}
    <meta name="twitter:card" content={socialImage ? 'summary_large_image' : 'summary'} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    {socialImage && <meta name="twitter:image" content={socialImage} />}
    <link rel="stylesheet" href="https://unpkg.com/@algolia/sitesearch@latest/dist/search.min.css" />
    <script is:inline async src="https://www.googletagmanager.com/gtag/js?id=G-PKB6YJE88Z"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());

      gtag('config', 'G-PKB6YJE88Z');
    </script>
    {jsonLdItems.map((item) => (
      <script is:inline type="application/ld+json" set:html={JSON.stringify(item).replace(/</g, '\\u003c')} />
    ))}
  </head>
  <body>
    <div id="top"></div>
    <div class="shell">
      <div class="panel">
        <slot />
        <div id="search" class="site-search" role="search" aria-label="サイト内検索"></div>
        <script is:inline src="https://unpkg.com/@algolia/sitesearch@latest/dist/search.min.js"></script>
        <script is:inline>
          const searchContainer = document.getElementById('search');
          const searchHost = document.querySelector('.site-header-search');
          const siteHeader = document.querySelector('.site-header');

          if (searchContainer && searchHost) {
            searchHost.appendChild(searchContainer);
          } else if (searchContainer && siteHeader) {
            siteHeader.appendChild(searchContainer);
          }

          SiteSearch.init({
            container: '#search',
            applicationId: 'LDI14IJOZS',
            apiKey: '7a0ef963c4a89f7a3dbe6fb174d0602f',
            indexName: 'bunkei_programmer_net_ldi14ijozs_pages',
            attributes: {
              primaryText: 'title',
              secondaryText: 'description',
              tertiaryText: 'path',
              url: 'path',
              image: '',
            },
            darkMode: false,
          });
        </script>
      </div>
    </div>
    <a class="scroll-to-top" href="#top" aria-label="トップへ戻る">
      ↑
    </a>
  </body>
</html>

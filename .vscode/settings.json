{
  "biome.enable": false,
  "breadcrumbs.enabled": true,
  "deno.enable": false,
  "editor.bracketPairColorization.enabled": true,
  "editor.codeActionsOnSave": {
    "source.addMissingImports": "explicit",
    "source.fixAll.oxc": "explicit",
    "source.organizeImports": "explicit",
    "source.removeUnusedImports": "explicit",
    "source.sort.json": "never",
    "source.sortImports": "explicit"
  },
  "editor.copyWithSyntaxHighlighting": false,
  "editor.defaultFormatter": "oxc.oxc-vscode",
  "editor.formatOnSave": true,
  "editor.formatOnSaveMode": "file",
  "editor.guides.bracketPairs": true,
  "editor.guides.highlightActiveIndentation": true,
  "editor.guides.indentation": true,
  "editor.hover.sticky": true,
  "editor.renderControlCharacters": true,
  "editor.stickyScroll.enabled": false,
  "files.associations": {
    "*.env.development": "env",
    "*.env.development.local": "env",
    "*.env.local": "env",
    "*.env.production": "env",
    "*.env.production.local": "env",
    "*.env.staging": "env",
    "*.env.staging.local": "env"
  },
  "files.exclude": {
    "**/.astro": true,
    "**/.DS_Store": true,
    "**/.tmp": true,
    "**/.wrangler": true,
    "**/.wrangler-logs": true,
    "**/dist": true,
    "**/node_modules": true
  },
  "files.insertFinalNewline": true,
  "git.mergeEditor": true,
  "js/ts.format.enabled": true,
  "js/ts.implementationsCodeLens.enabled": true,
  "js/ts.inlayHints.enumMemberValues.enabled": true,
  "js/ts.inlayHints.functionLikeReturnTypes.enabled": true,
  "js/ts.inlayHints.parameterNames.enabled": "all",
  "js/ts.inlayHints.parameterTypes.enabled": true,
  "js/ts.inlayHints.propertyDeclarationTypes.enabled": true,
  "js/ts.inlayHints.variableTypes.enabled": false,
  "js/ts.preferences.importModuleSpecifier": "non-relative",
  "js/ts.preferences.preferTypeOnlyAutoImports": false,
  "js/ts.referencesCodeLens.enabled": true,
  "js/ts.referencesCodeLens.showOnAllFunctions": false,
  "js/ts.suggest.autoImports": true,
  "js/ts.tsdk.path": "node_modules/typescript/lib",
  "oxc.enable": true,
  "oxc.enable.oxfmt": true,
  "oxc.enable.oxlint": true,
  "oxc.typeAware": true,
  "prettier.enable": false,
  "search.exclude": {
    ".idea": true,
    "**/__snapshots__": true,
    "**/.astro": true,
    "**/.tmp": true,
    "**/.wrangler": true,
    "**/.wrangler-logs": true,
    "**/*.svg": true,
    "**/dist": true,
    "**/node_modules": true,
    "build": true,
    "bun.lock": true,
    "bun.lockb": true,
    "package-lock.json": true,
    "pnpm-lock.yaml": true,
    "yarn.lock": true
  },
  "workbench.editor.closeEmptyGroups": true,
  "workbench.editor.enablePreview": false,
  "workbench.tree.indent": 16,
  "workbench.tree.renderIndentGuides": "always",
  "[markdown]": {
    "editor.defaultFormatter": "fcrespo82.markdown-table-formatter",
  }
}
